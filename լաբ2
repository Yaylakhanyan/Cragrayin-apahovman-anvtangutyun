#include <iostream>
#include <vector>

using namespace std;

// Структура переименована, поля тоже
struct CodedItem {
    int freq;
    int num;
};

// Функция кодирования
vector<CodedItem> compressData(const vector<int>& inputArr) {
    vector<CodedItem> result;
    if (inputArr.size() == 0) {
        return result;
    }

    int reps = 1;
    int activeVal = inputArr[0];

    // Использован while вместо for
    size_t idx = 1;
    while (idx < inputArr.size()) {
        if (inputArr[idx] == activeVal && reps < 255) {
            reps += 1;
        } else {
            // Немного изменена логика if-else местами
            if (activeVal <= 255) {
                result.push_back({reps, activeVal});
            } else {
                int leftOver = activeVal;
                while (leftOver > 255) {
                    result.push_back({1, 255});
                    leftOver = leftOver - 255;
                }
                result.push_back({1, leftOver});
            }

            activeVal = inputArr[idx];
            reps = 1;
        }
        idx++;
    }

    // Обработка последнего элемента
    if (activeVal <= 255) {
        result.push_back({reps, activeVal});
    } else {
        int leftOver = activeVal;
        while (leftOver > 255) {
            result.push_back({1, 255});
            leftOver -= 255;
        }
        result.push_back({1, leftOver});
    }

    return result;
}

// Функция декодирования
vector<int> decompressData(const vector<CodedItem>& compressed) {
    vector<int> unpacked;
    int sumVal = 0;

    // Обычный for вместо range-based (auto& p)
    for (size_t k = 0; k < compressed.size(); k++) {
        int c = compressed[k].freq;
        int v = compressed[k].num;

        if (c == 1 && v == 255) {
            sumVal += 255;
        } 
        else if (c == 1 && sumVal > 0) {
            sumVal += v;
            unpacked.push_back(sumVal);
            sumVal = 0;
        } 
        else {
            int j = 0;
            while (j < c) {
                unpacked.push_back(v);
                j++;
            }
        }
    }

    return unpacked;
}

// Главная функция
int main() {
    int arrSize;
    cout << "Ներմուծեք զանգվածի չափը՝ ";
    cin >> arrSize;

    if (arrSize < 1) {
        cout << "Սխալ: Զանգվածը դատարկ է:\n";
        return 0;
    }

    vector<int> source(arrSize);

    cout << "Գրեք զանգվածի " << arrSize << " թվերը:\n-> ";
    for (int i = 0; i < arrSize; i++) {
        cin >> source[i];
    }

    // Кодируем
    vector<CodedItem> encodedArr = compressData(source);

    cout << "\n=== ԿՈԴԱՎՈՐՎԱԾ (ENCODE) ===\n";
    for (size_t i = 0; i < encodedArr.size(); i++) {
        cout << "(" << encodedArr[i].freq << ", " << encodedArr[i].num << ") ";
    }
    cout << "\n";

    // Декодируем
    vector<int> decodedArr = decompressData(encodedArr);

    cout << "\n=== ՎԵՐԱԿԱՆԳՆՎԱԾ (DECODE) ===\n";
    for (size_t i = 0; i < decodedArr.size(); i++) {
        cout << decodedArr[i] << " ";
    }

    // Ручная проверка массивов вместо (original == decoded)
    cout << "\n\n=== ՍՏՈՒԳՄԱՆ ԱՐԴՅՈՒՆՔ === \nՀամընկնում է՞: ";
    
    bool isMatch = true;
    if (source.size() != decodedArr.size()) {
        isMatch = false;
    } else {
        for (size_t i = 0; i < source.size(); i++) {
            if (source[i] != decodedArr[i]) {
                isMatch = false;
                break;
            }
        }
    }

    if (isMatch) {
        cout << "ԱՅՈ\n";
    } else {
        cout << "ՈՉ\n";
    }

    return 0;
}
